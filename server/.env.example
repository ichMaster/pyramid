# Pyramid server config — copy to `server/.env` and fill in (never commit `.env`).
# Tests use mock providers and read none of these, so CI needs no secrets.

# --- server ---
PYRAMID_HOST=127.0.0.1
PYRAMID_PORT=8000
PYRAMID_ENV=dev
PYRAMID_SESSION_IDLE_TIMEOUT_S=600

# --- LLM (Anthropic Messages API, SSE streaming) ---
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-3-5-haiku-latest

# --- ASR (Deepgram) ---
ASR_API_KEY=...

# --- TTS (ElevenLabs, pcm_16000) ---
TTS_API_KEY=...
TTS_VOICE_ID=...
